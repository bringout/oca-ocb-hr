msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <div style=\"text-align: center\">\n"
"        <h2>Čestitamo!</h2>\n"
"        <div style=\"color:grey;\">Vaš CV je pozitivno ocijenjen.</div>\n"
"    </div>\n"
"    <div style=\"font-size: 13px; margin: 0px; padding: 0px;\">\n"
"        Upravo smo pregledali vaš CV i privukao je našu\n"
"        pažnju. Pošto smatramo da biste mogli biti odlični za\n"
"        ovu poziciju, vaša prijava je uvrštena u uži izbor za\n"
"        poziv ili razgovor.\n"
"        <br/><br/>\n"
"        <div t-if=\"'website_url' in object.job_id and object.job_id.website_url\" style=\"padding: 16px 8px 16px 8px;\">\n"
"            <a t-att-href=\"object.job_id.website_url\" t-attf-style=\"background-color: {{object.company_id.email_secondary_color or '#875A7B'}}; text-decoration: none; color: {{object.company_id.email_primary_color or '#FFFFFF'}}; padding: 8px 16px 8px 16px; border-radius: 5px;\">Opis posla</a>\n"
"        </div>\n"
"\n"
"        <t t-if=\"object.recruiter_id and object.recruiter_id.user_id\">\n"
"            Uskoro će vas kontaktirati:<br/>\n"
"            <strong t-out=\"object.recruiter_id.name or ''\">Mitchell Admin</strong><br/>\n"
"            <span>Email: <t t-out=\"object.recruiter_id.work_email or ''\">admin@yourcompany.example.com</t></span><br/>\n"
"            <span>Telefon: <t t-out=\"object.recruiter_id.work_phone or ''\">+1 650-123-4567</t></span>\n"
"            <br/><br/>\n"
"        </t>\n"
"        Vidimo se uskoro,\n"
"        <div style=\"font-size: 11px; color: grey;\">\n"
"            -- <br/>\n"
"            HR tim\n"
"            <t t-if=\"'website_url' in object.job_id and hasattr(object.job_id, 'website_url') and object.job_id.website_url\">\n"
"                Otkrijte <a href=\"/jobs\" style=\"text-decoration:none;color:#717188;\">sve naše poslove</a>.<br/>\n"
"            </t>\n"
"        </div>\n"
"\n"
"        <hr width=\"97%\" style=\"background-color: rgb(204,204,204); border: medium none; clear: both; display: block; font-size: 0px; min-height: 1px; line-height: 0; margin: 16px 0px 16px 0px;\"/>\n"
"        <h3 style=\"color:#9A6C8E;\"><strong>Šta je sljedeći korak?</strong></h3>\n"
"        Obično <strong>odgovaramo na prijave u roku od nekoliko dana</strong>.\n"
"        <br/><br/>\n"
"        Sljedeći korak je ili poziv ili sastanak u našim uredima.\n"
"        <br/>\n"
"        Slobodno nas <strong>kontaktirajte ako želite brži\n"
"        odgovor</strong> ili ako nemate vijesti od nas\n"
"        dovoljno brzo (samo odgovorite na ovaj email).\n"
"        <br/>\n"
"\n"
"        <hr width=\"97%\" style=\"background-color: rgb(204,204,204); border: medium none; clear: both; display: block; font-size: 0px; min-height: 1px; line-height: 0; margin: 17px 0px 16px 0px;\"/>\n"
"        <t t-set=\"location\" t-value=\"''\"/>\n"
"        <t t-if=\"object.job_id.address_id.name\">\n"
"            <strong t-out=\"object.job_id.address_id.name or ''\">Teksa SpA</strong><br/>\n"
"        </t>\n"
"        <t t-if=\"object.job_id.address_id.street\">\n"
"            <t t-out=\"object.job_id.address_id.street or ''\">Puerto Madero 9710</t><br/>\n"
"            <t t-set=\"location\" t-value=\"object.job_id.address_id.street\"/>\n"
"        </t>\n"
"        <t t-if=\"object.job_id.address_id.street2\">\n"
"            <t t-out=\"object.job_id.address_id.street2 or ''\">Of A15, Santiago (RM)</t><br/>\n"
"            <t t-set=\"location\" t-value=\"'%s, %s' % (location, object.job_id.address_id.street2)\"/>\n"
"        </t>\n"
"        <t t-if=\"object.job_id.address_id.city\">\n"
