msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <div style=\"text-align: center\">\n"
"        <h2>Čestitamo!</h2>\n"
"        <div style=\"color:grey;\">Vaša biografija je pozitivno ocijenjena.</div>\n"
"    </div>\n"
"    <div style=\"font-size: 13px; margin: 0px; padding: 0px;\">\n"
"        Upravo smo pregledali vašu biografiju i privukla nam je\n"
"        pažnju. S obzirom da mislimo da biste mogli biti odlični za\n"
"        ovu poziciju, vaša prijava je uvrštena u uži izbor za\n"
"        poziv ili intervju.\n"
"        <br/><br/>\n"
"        <div t-if=\"'website_url' in object.job_id and object.job_id.website_url\" style=\"padding: 16px 8px 16px 8px;\">\n"
"            <a t-att-href=\"object.job_id.website_url\" t-attf-style=\"background-color: {{object.company_id.email_secondary_color or '#875A7B'}}; text-decoration: none; color: {{object.company_id.email_primary_color or '#FFFFFF'}}; padding: 8px 16px 8px 16px; border-radius: 5px;\">Opis posla</a>\n"
"        </div>\n"
"\n"
"        <t t-if=\"object.user_id\">\n"
"            Uskoro će vas kontaktirati:<br/>\n"
"            <strong t-out=\"object.user_id.name or ''\">Mitchell Admin</strong><br/>\n"
"            <span>Email: <t t-out=\"object.user_id.email or ''\">admin@yourcompany.example.com</t></span><br/>\n"
"            <span>Telefon: <t t-out=\"object.user_id.phone or ''\">+1 650-123-4567</t></span>\n"
"            <br/><br/>\n"
"        </t>\n"
"        Vidimo se uskoro,\n"
"        <div style=\"font-size: 11px; color: grey;\">\n"
"            -- <br/>\n"
"            HR tim\n"
"            <t t-if=\"'website_url' in object.job_id and hasattr(object.job_id, 'website_url') and object.job_id.website_url\">\n"
"                Otkrijte <a href=\"/jobs\" style=\"text-decoration:none;color:#717188;\">sve naše poslove</a>.<br/>\n"
"            </t>\n"
"        </div>\n"
"\n"
"        <hr width=\"97%\" style=\"background-color: rgb(204,204,204); border: medium none; clear: both; display: block; font-size: 0px; min-height: 1px; line-height: 0; margin: 16px 0px 16px 0px;\"/>\n"
"        <h3 style=\"color:#9A6C8E;\"><strong>Koji je sljedeći korak?</strong></h3>\n"
"        Obično <strong>odgovaramo na prijave u roku od nekoliko dana</strong>.\n"
"        <br/><br/>\n"
"        Sljedeći korak je poziv ili sastanak u našim prostorijama.\n"
"        <br/>\n"
"        Slobodno nas <strong>kontaktirajte ako želite brži\n"
"        odgovor</strong> ili ako se ne javimo\n"
"        dovoljno brzo (samo odgovorite na ovaj email).\n"
"        <br/>\n"
"\n"
"        <hr width=\"97%\" style=\"background-color: rgb(204,204,204); border: medium none; clear: both; display: block; font-size: 0px; min-height: 1px; line-height: 0; margin: 17px 0px 16px 0px;\"/>\n"
