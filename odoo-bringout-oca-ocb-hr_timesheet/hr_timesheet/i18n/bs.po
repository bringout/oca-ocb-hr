msgid ""
"Use these keywords in the title to set new tasks:\n"
"\n"
"        30h Allocate 30 hours to the task\n"
"        #tags Set tags on the task\n"
"        @user Assign the task to a user\n"
"        ! Set the task a medium priority\n"
"        !! Set the task a high priority\n"
"        !!! Set the task a urgent priority\n"
"\n"
"        Make sure to use the right format and order e.g. Improve the configuration screen 5h #feature #v16 @Mitchell !"
msgstr ""
"Koristite ove ključne riječi u naslovu za postavljanje novih zadataka:\n"
"\n"
"        30h Dodijeli 30 sati zadatku\n"
"        #tags Postavi oznake na zadatku\n"
"        @user Dodijeli zadatak korisniku\n"
"        ! Postavi zadatku srednji prioritet\n"
"        !! Postavi zadatku visok prioritet\n"
"        !!! Postavi zadatku hitan prioritet\n"
"\n"
"        Pazite da koristite ispravan format i redoslijed npr. Improve the configuration screen 5h #feature #v16 @Mitchell !"

